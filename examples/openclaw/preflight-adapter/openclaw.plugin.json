{
  "id": "neura-relay-preflight-adapter",
  "name": "Neura Relay Preflight Adapter",
  "description": "Routes refs-only proposed local actions through Neura Relay before developer-owned execution.",
  "version": "0.1.0-rc.1",
  "contracts": {
    "tools": ["neura_relay_preflight_action"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "relayBaseUrl": {
        "type": "string",
        "default": "https://www.neurarelay.com"
      }
    }
  }
}
