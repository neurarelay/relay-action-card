{
  "name": "@neurarelay/openclaw-preflight-adapter-example",
  "version": "0.1.0-rc.0",
  "private": true,
  "type": "module",
  "description": "Unofficial OpenClaw-style preflight adapter example for Neura Relay Decision Receipts.",
  "exports": {
    ".": "./index.mjs",
    "./adapter": "./adapter.mjs"
  },
  "openclaw": {
    "extensions": ["./index.mjs"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.3.24-beta.2",
      "pluginSdkVersion": "2026.3.24-beta.2"
    }
  },
  "neura": {
    "officialOpenClawOrClawHubClaim": false,
    "downstreamExecutionByNeura": false,
    "privatePayloadExposure": false,
    "publicTokenOrKeyIssuance": false
  }
}
